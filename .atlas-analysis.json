  "keyFeatures": [
    "Visual workflow builder with React Flow",
    "Human-in-the-loop task approvals",
    "Priority chain and approval policies",
    "Subworkflow support with parent-child linking",
    "Better Auth email/password authentication",
    "RabbitMQ-backed async notifications",
    "Immutable workflow versioning",
    "Full audit trail and action history"
  ],
  "publicApiSurface": [
    "POST /api/v1/workflow-definitions - Create workflow definition",
    "PUT /api/v1/workflow-definitions/{id} - Update workflow definition",
    "POST /api/v1/workflow-definitions/{id}/publish - Publish workflow version",
    "POST /api/v1/workflow-instances - Start workflow instance",
    "GET /api/v1/workflow-instances/{id} - Get workflow instance details",
    "GET /api/v1/me/tasks - List current user's tasks",
    "POST /api/v1/human-tasks/{id}/approve - Approve a task",
    "POST /api/v1/human-tasks/{id}/reject - Reject a task",
    "POST /api/v1/human-tasks/{id}/revert - Revert a task",
    "GET /api/v1/me/notifications - List user notifications"
  ]
